# EDA - Données de courbes de taux souverains et swaps
# ============================================================
library(readxl)
library(dplyr)
library(lubridate)
# ---- 1. Chargement des données ----
# Snapshots cross-sectionnels (une date d'observation unique)
fr_cs   <- read.csv("r_data/StatApp_Data1_France.csv")
de_cs   <- read.csv("r_data/StatApp_Data1_Allemagne.csv")
it_cs   <- read.csv("r_data/StatApp_Data1_Italie.csv")
swap_cs <- read.csv("r_data/StatApp_Data1_Swap.csv")
# Panels temporels (plusieurs dates d'observation)
fr_ts <- read_excel("r_data/souverain_cross_temporel_france.xlsx")
de_ts <- read_excel("r_data/souverain_cross_temporel_allemagne.xlsx")
# Renommage pour homogénéité
colnames(fr_cs)[2] <- "Yield"
colnames(de_cs)[2] <- "Yield"
colnames(it_cs)[2] <- "Yield"
colnames(swap_cs)[3] <- "Yield"
fr_cs$Maturity <- as.Date(fr_cs$Maturity, format = "%d/%m/%Y")
de_cs$Maturity <- as.Date(de_cs$Maturity, format = "%d/%m/%Y")
it_cs$Maturity <- as.Date(it_cs$Maturity, format = "%d/%m/%Y")
# ---- 2. Fonction résumé générique ----
desc_summary <- function(df, name, yield_col = "Yield", maturity_col = NULL, date_col = NULL) {
y <- suppressWarnings(as.numeric(df[[yield_col]]))
cat(sprintf("\n=== %s ===\n", name))
cat(sprintf("  Observations      : %d\n", sum(!is.na(y))))
cat(sprintf("  Rendement min     : %.3f%%\n", min(y, na.rm = TRUE)))
cat(sprintf("  Rendement max     : %.3f%%\n", max(y, na.rm = TRUE)))
cat(sprintf("  Rendement moyen   : %.3f%%\n", mean(y, na.rm = TRUE)))
cat(sprintf("  Écart-type        : %.3f%%\n", sd(y, na.rm = TRUE)))
if (!is.null(maturity_col)) {
m <- df[[maturity_col]]
cat(sprintf("  Maturité min      : %s\n", as.character(min(m, na.rm = TRUE))))
cat(sprintf("  Maturité max      : %s\n", as.character(max(m, na.rm = TRUE))))
}
if (!is.null(date_col)) {
d <- df[[date_col]]
cat(sprintf("  Dates             : %s → %s\n",
as.character(min(d, na.rm = TRUE)),
as.character(max(d, na.rm = TRUE))))
n_dates <- length(unique(d))
cat(sprintf("  Nombre de dates   : %d\n", n_dates))
# Obligations uniques par date
n_bonds <- nrow(df) / n_dates
cat(sprintf("  Obligations/date  : %.0f (moy.)\n", n_bonds))
}
}
# ---- 3. Statistiques descriptives ----
cat("╔══════════════════════════════════════════════════════╗")
cat("\n║  DONNÉES CROSS-SECTIONNELLES (snapshot)              ║")
cat("\n╚══════════════════════════════════════════════════════╝\n")
desc_summary(fr_cs, "OAT France",    maturity_col = "Maturity")
desc_summary(de_cs, "Bund Allemagne",maturity_col = "Maturity")
desc_summary(it_cs, "BTP Italie",    maturity_col = "Maturity")
desc_summary(swap_cs, "EUR Swap (OIS/IRS)")
cat("\n╔══════════════════════════════════════════════════════╗")
cat("\n║  DONNÉES PANEL TEMPOREL                              ║")
cat("\n╚══════════════════════════════════════════════════════╝\n")
desc_summary(fr_ts, "OAT France (panel)",
yield_col = "Yield", date_col = "Date_observation")
desc_summary(de_ts, "Bund Allemagne (panel)",
yield_col = "Yield", date_col = "Date_observation")
# ---- 4. Étendue des maturités (Time-to-Maturity) ----
cat("\n=== Étendue des maturités (Time-To-Maturity, en années) ===\n")
for (lst in list(list(fr_ts, "France"), list(de_ts, "Allemagne"))) {
df   <- lst[[1]]
name <- lst[[2]]
ttm  <- df$Time_To_Maturity
cat(sprintf("  %-12s : [%.2f ; %.2f] ans  —  médiane %.2f ans\n",
name, min(ttm), max(ttm), median(ttm)))
}
# ---- 5. Tableau récapitulatif compact (optionnel : export CSV) ----
recap <- data.frame(
Source    = c("OAT France", "Bund Allemagne", "BTP Italie", "EUR Swap"),
N_obs     = c(nrow(fr_cs), nrow(de_cs), nrow(it_cs), nrow(swap_cs)),
Yield_min = c(min(fr_cs$Yield), min(de_cs$Yield),
min(it_cs$Yield), min(swap_cs$Yield, na.rm = TRUE)),
Yield_max = c(max(fr_cs$Yield), max(de_cs$Yield),
max(it_cs$Yield), max(swap_cs$Yield, na.rm = TRUE)),
Yield_mean= c(mean(fr_cs$Yield), mean(de_cs$Yield),
mean(it_cs$Yield), mean(swap_cs$Yield, na.rm = TRUE)),
Yield_sd  = c(sd(fr_cs$Yield), sd(de_cs$Yield),
sd(it_cs$Yield), sd(swap_cs$Yield, na.rm = TRUE))
)
recap[, 3:6] <- round(recap[, 3:6], 3)
rm(list = ls())
