mean(y_it, na.rm=TRUE), mean(y_swap, na.rm=TRUE)),
Yield_sd   = c(sd(y_fr, na.rm=TRUE), sd(y_de, na.rm=TRUE),
sd(y_it, na.rm=TRUE), sd(y_swap, na.rm=TRUE))
)
